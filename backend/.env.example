# ---- Server ----
PORT=5000

# ---- MySQL Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=fyp_archive

# Set DB_SSL=true ONLY when connecting to a hosted MySQL provider
# (Aiven, TiDB Cloud, etc.). Leave it false/unset for local development.
DB_SSL=false

# ---- JWT ----
# Use a long, random string in production (e.g. output of: openssl rand -hex 32)
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d
